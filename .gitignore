# Virtual environment
.venv/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environment variables — never committed
.env
.env.*
!.env.example

# SQLite databases
*.db
*.sqlite
*.sqlite3

# IDEs / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
**/.DS_Store

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# uv
uv.lock

# Markdown working docs — internal only
# Exceptions: README.md and architecture.md are public-facing
*.md
!README.md
!architecture.md
docs/

# Context-bridge artifacts (accidentally ended up in source_docs)
source_docs/context-bridge-*

# Corpus raw files are committed; generated embeddings/db are not
corpus/*.db
corpus/*.sqlite
# SQLite WAL/SHM sidecars — never commit these; delete obs.db* to clear history
corpus/*.db-wal
corpus/*.db-shm

# Run logs and output artifacts
*.log
server_*.log
qa_*.log
*_results.json
*.zip

# Claude Code session metadata
.claude/

# E2E test screenshots — generated artifacts, not source
tests/screenshots/
