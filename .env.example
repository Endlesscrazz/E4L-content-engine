# E4L Content Engine — Environment Variables
# Copy to .env (or .env.local for local dev) and fill in your keys.
# Never commit .env or .env.local — both are gitignored.

# Anthropic — Orchestrator (Haiku 4.5), Writer (Sonnet 4.6), Validator (Opus 4.7)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — corpus embeddings (gemini-embedding-001, 3072-dim)
GEMINI_API_KEY=AIza...

# Brave Search — Researcher web search tool
BRAVE_API_KEY=BSA...
